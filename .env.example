# Required
ANTHROPIC_API_KEY=sk-ant-...

# Voice (STT via Whisper + TTS)
# Option A — standard OpenAI
OPENAI_API_KEY=sk-...
# Option B — Azure (dedicated TTS resource, e.g. services.ai.azure.com)
# AZURE_TTS_ENDPOINT=https://anjo-tts-resource.services.ai.azure.com
# AZURE_TTS_DEPLOYMENT=tts            # deployment name in Azure
# AZURE_TTS_API_VERSION=2025-01-01-preview
# Option C — Azure shared resource (uses AZURE_API_BASE + AZURE_API_KEY above)
# AZURE_WHISPER_DEPLOYMENT=whisper
# AZURE_TTS_DEPLOYMENT=tts
# Optional voice config
# ANJO_TTS_VOICE=nova                 # alloy, echo, fable, onyx, nova, shimmer

# Auth — use a long random string in production
ANJO_SECRET=change_me_to_a_long_random_string

# App URL
ANJO_BASE_URL=https://anjo.love

# Optional — email verification + password reset
RESEND_API_KEY=re_...

# Billing — RevenueCat
REVENUECAT_WEBHOOK_SECRET=

# Extended thinking (Sonnet respond node only — incompatible with prompt caching)
# Verify Bedrock supports extended thinking before enabling in production
ANJO_THINKING_ENABLED=false
ANJO_THINKING_BUDGET=3000
