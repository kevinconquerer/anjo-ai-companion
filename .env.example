# Required
ANTHROPIC_API_KEY=sk-ant-...

# Auth — use a long random string in production
ANJO_SECRET=change_me_to_a_long_random_string

# Admin panel — access at /admin?key=<this value>
ANJO_ADMIN_SECRET=change_me_to_another_long_random_string

# App URL
ANJO_BASE_URL=http://localhost:8000

# Optional — email verification + password reset (skip to auto-verify all users)
RESEND_API_KEY=re_...

# Extended thinking (Sonnet respond node only)
ANJO_THINKING_ENABLED=false
ANJO_THINKING_BUDGET=3000
